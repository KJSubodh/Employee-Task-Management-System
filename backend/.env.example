# ===========================
# SERVER CONFIGURATION
# ===========================
PORT=5000
NODE_ENV=development

# ===========================
# DATABASE CONFIGURATION (MySQL)
# ===========================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=task_management
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_DIALECT=mysql
DB_LOGGING=false

# ===========================
# JWT CONFIGURATION
# ===========================
# Generate your own with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Never reuse the example/placeholder value below in a real deployment.
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRE=7d

# ===========================
# EMAIL CONFIGURATION (Optional)
# ===========================
# Leave as-is if you don't need email notifications - the app degrades
# gracefully and just logs "Email not sent (transporter not configured)".
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here
EMAIL_FROM=noreply@taskmanager.com

# ===========================
# FILE UPLOAD CONFIGURATION
# ===========================
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads

# ===========================
# CORS CONFIGURATION
# ===========================
CORS_ORIGIN=http://localhost:3000

# ===========================
# LOGGING
# ===========================
LOG_LEVEL=info
